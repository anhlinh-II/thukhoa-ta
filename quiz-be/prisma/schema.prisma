datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum LearningType {
  NEW
  LEARNING
  REVIEW
  RELEARNING
}

/// User model
model User {
  created_at                  DateTime           @default(now())
  created_by                  String?
  updated_at                  DateTime           @updatedAt()
  updated_by                  String?
  id                          String             @id() @default(cuid())
  avatar_url                  String?
  bio                         String?
  dob                         DateTime?
  email                       String             @unique()
  first_name                  String?
  full_name                   String?
  gender                      String?
  google_id                   String?            @unique()
  is_active                   Boolean            @default(true)
  is_delete                   Boolean            @default(false)
  last_name                   String?
  locale                      String?
  location                    String?
  otp                         String?
  otp_generated_time          DateTime?
  password                    String
  phone                       String?    @unique()
  refresh_token               String?    @db.Text
  reset_password_token        String?
  reset_password_token_expiry DateTime?
  username                    String             @unique()
  current_streak              Int                @default(0)
  last_activity_date          DateTime?
  longest_streak              Int                @default(0)
  ranking_points              Int                @default(0)
  total_quizzes_completed     Int                @default(0)
  posts                       Post[]
  user_roles                  UserRole[]
  user_learning_items         UserLearningItem[]
}

/// Role model
model Role {
  created_at  DateTime         @default(now())
  created_by  String?
  updated_at  DateTime         @updatedAt()
  updated_by  String?
  id          Int              @id() @default(autoincrement())
  authority   String           @unique()
  description String?
  users       UserRole[]
  permissions RolePermission[]
}

/// Permission model
model Permission {
  created_at  DateTime         @default(now())
  created_by  String?
  updated_at  DateTime         @updatedAt()
  updated_by  String?
  id          Int              @id() @default(autoincrement())
  name        String
  description String?
  resource    String
  action      String
  roles       RolePermission[]

  @@unique([resource, action])
}

/// User-role link
model UserRole {
  created_at DateTime @default(now())
  created_by String?
  updated_at DateTime @updatedAt()
  updated_by String?
  user_id    String
  role_id    Int
  assignedAt DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
}

/// Role-permission link
model RolePermission {
  created_at    DateTime   @default(now())
  created_by    String?
  updated_at    DateTime   @updatedAt()
  updated_by    String?
  role_id       Int
  permission_id Int
  assignedAt    DateTime   @default(now())
  role          Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
}

/// Post model
model Post {
  created_at DateTime @default(now())
  created_by String?
  updated_at DateTime @updatedAt()
  updated_by String?
  id         String   @id() @default(cuid())
  title      String
  content    String
  published  Boolean  @default(false)
  author     User     @relation(fields: [authorId], references: [id])
  authorId   String
}

/// User learning item model
model UserLearningItem {
  created_at        DateTime     @default(now())
  created_by        String?
  updated_at        DateTime     @updatedAt()
  updated_by        String?
  id                BigInt       @id() @default(autoincrement())
  user              User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id           String
  question_id       BigInt
  ef                Float?
  repetitions       Int?
  interval_days     Int?
  next_review_at    DateTime?
  last_reviewed_at  DateTime?
  lapses            Int?
  consecutive_fails Int?
  priority          Float?
  learning_type     LearningType

  @@unique([user_id, question_id])
  @@index([user_id])
  @@index([question_id])
}
